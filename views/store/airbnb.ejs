<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-100 via-red-50 to-orange-100 min-h-screen">

  <!-- ✅ Header -->
  <%- include('../partials/nav') %>

  <!-- ✅ Main Content -->
  <main class="container mx-auto px-6 py-12">
    <h2 class="text-4xl font-extrabold text-gray-900 mb-10 text-center">
      Explore Our Homes
    </h2>

    <!-- ✅ Grid Layout -->
    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% registerhomes.forEach(home => { %>
        <li class="bg-white/90 backdrop-blur-md rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:scale-[1.03] transform transition duration-300 border border-gray-200">
          
          <!-- Image Wrapper -->
          <div class="relative">
            <img 
              src="<%= home.photo %>" 
              alt="<%= home.houseName %>" 
              class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500"
            />
            <!-- Favorite Button -->
            <button class="absolute top-3 right-3 bg-white/90 p-2 rounded-full shadow-md hover:bg-red-100 transition">
              ❤️
            </button>
          </div>

          <!-- Info -->
          <div class="p-5">
            <div class="flex justify-between items-center mb-2">
              <h2 class="text-xl font-bold text-gray-900 truncate"><%= home.houseName %></h2>
              <span class="text-yellow-500 font-semibold">⭐ <%= home.rating %></span>
            </div>
            <p class="text-gray-600 text-base mb-2"><%= home.location %></p>
            <p class="text-red-600 font-bold text-lg">₹<%= home.price %> <span class="text-gray-500 font-normal">/ night</span></p>
          </div>
          
          <!-- Button -->
          <div class="p-5 border-t">
            <button class="w-full bg-gradient-to-r from-red-500 to-pink-500 text-white font-semibold py-3 rounded-lg hover:from-red-600 hover:to-pink-600 transition shadow-md hover:shadow-lg">
              Book Now
            </button>
          </div>
          
        </li>
      <% }) %>
    </ul>
  </main>

</body>
</html>
