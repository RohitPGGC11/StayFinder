<%- include('../partials/head')  %>
</head>
<body class="bg-gradient-to-br from-pink-100 via-red-50 to-orange-100 font-sans min-h-screen">

<!-- ✅ Header -->
<%- include('../partials/nav')  %>

<!-- ✅ Main Content -->
<main class="container mx-auto px-6 py-10">
  <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">
    Explore our Homes
  </h2>

  <!-- ✅ Grid Layout -->
  <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% favouritehomes.forEach(home => { %>
      <li class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:scale-[1.02] transform transition duration-300">
        
        <!-- Image -->
        <img 
          src="<%= home.photo %>" 
          alt="<%= home.houseName %>" 
          class="w-full h-52 object-cover"
        />

        <!-- Info -->
        <div class="p-4">
          <div class="flex justify-between items-center mb-2">
            <h2 class="text-lg font-semibold text-gray-900"><%= home.houseName %></h2>
            <span class="text-yellow-500 font-medium">⭐ <%= home.rating %></span>
          </div>
          <p class="text-gray-600 text-2xl mb-1"><%= home.location %></p>
          <p class="text-red-600 font-bold">₹<%= home.price %> <span class="text-black font-normal">/ night</span></p>
        </div>
        
       

        <!-- Button -->
        <div class="p-4 border-t  flex gap-2">
         
         <a href="/home/<%= home._id %>" class="px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition">Details</a>
        
         <form action="/delete/<%= home._id %>" method="POST">
        <button type="submit" class="px-5 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition cursor-pointer">Remove from favourites</button>
          </form>
        </div>
        
      </li>
    <% }) %>
  </ul>
</main>

</body>
</html>
