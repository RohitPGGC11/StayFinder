<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-100 via-red-50 to-orange-100 min-h-screen flex flex-col">
  <%- include('../partials/nav') %>

  <main class="flex flex-1 items-center justify-center px-4 py-20">
    <form action="/login" method="post" 
      class="bg-white/90 backdrop-blur-md p-8 rounded-2xl shadow-xl w-full max-w-md border border-gray-200">
      
      <!-- Title -->
      <h2 class="text-3xl font-extrabold mb-6 text-center text-gray-800">
        Welcome Back 👋
      </h2>
      
      <%- include('../partials/errors')%>

      <!-- Email -->
      <div class="relative mb-4">
        <input 
          type="email" 
          name="email" 
          placeholder="Enter your Email" 
          value="<%= OldInput.email ? OldInput.email : '' %>"
          class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
          required
        />
        <span class="absolute inset-y-0 left-3 flex items-center text-gray-400">
          📧
        </span>
      </div>

      <!-- Password -->
      <div class="relative mb-6">
        <input 
          type="password" 
          name="password" 
          placeholder="Password" 
          class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
          required
        />
        <span class="absolute inset-y-0 left-3 flex items-center text-gray-400">
          🔒
        </span>
      </div>

      <!-- Submit -->
      <button 
        type="submit"
        class="w-full bg-gradient-to-r from-red-500 to-pink-500 text-white font-semibold py-3 rounded-lg hover:from-red-600 hover:to-pink-600 transition duration-300 shadow-md hover:shadow-lg cursor-pointer"
      >
        Sign In
      </button>

      <!-- Links -->
      <div class="mt-6 text-center">
        <p class="text-gray-600">
          Don’t have an account? 
          <a href="/signup" class="text-red-500 hover:text-red-700 font-semibold ">Sign up</a>
        </p>
      </div>

      <div class="mt-4 text-center">
        <a href="/forgot-password" class="text-sm text-gray-500 hover:text-gray-700">
          Forgot your password?
        </a>
      </div>
    </form>
  </main>
</body>
</html>
