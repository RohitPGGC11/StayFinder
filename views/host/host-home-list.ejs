<%- include('../partials/head')  %>
</head>
<body class="bg-gradient-to-br from-pink-100 via-red-50 to-orange-100 font-sans min-h-screen">

<!-- ✅ Header -->
<%- include('../partials/nav')  %>

<!-- ✅ Main Content -->
<main class="container mx-auto px-6 py-10">
  <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">
    Manage Your Homes
  </h2>

  <!-- ✅ Grid Layout -->
  <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% registerhomes.forEach(home => { %>
      <li class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:scale-[1.02] transform transition duration-300">
        
        <!-- Image -->
        <img 
          src="<%= home.photo %>" 
          alt="<%= home.houseName %>" 
          class="w-full h-52 object-cover"
        />

        <!-- Info -->
        <div class="p-4">
          <div class="flex justify-between items-center mb-2">
            <h2 class="text-lg font-semibold text-gray-900"><%= home.houseName %></h2>
            <span class="text-yellow-500 font-medium">⭐ <%= home.rating %></span>
          </div>
          <p class="text-gray-600 text-lg mb-1"><%= home.location %></p>
          <p class="text-red-600 font-bold">₹<%= home.price %> <span class="text-gray-700 font-normal">/ night</span></p>
        </div>

        <!-- Actions -->
        <div class="p-4 border-t flex gap-3">
          <a href="edit-home/<%= home._id %>?editing=true" 
             class="flex-1 text-center px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">
            ✏️ Edit
          </a>
          
          <form action="delete-home/<%= home._id %>" method="post" class="flex-1">
            <button type="submit" 
                    class="w-full px-4 py-2 border border-red-500 text-white rounded-lg bg-red-500 hover:bg-red-600 transition cursor-pointer">
              🗑️ Delete
            </button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
</main>

</body>
</html>
