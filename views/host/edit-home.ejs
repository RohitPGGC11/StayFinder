<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-100 via-red-50 to-orange-100 min-h-screen flex flex-col">
  <%- include('../partials/nav') %>

  <main class="flex flex-1 items-center justify-center px-6 py-8">
    <form action="/<%= editing ? 'edit-home' : 'add-home' %>" method="post" " enctype="multipart/form-data"
      class="bg-white/95 backdrop-blur-md p-8 rounded-2xl shadow-xl w-full max-w-lg border border-gray-200 space-y-5">
      
      <!-- Title with Icon -->
      <div class="text-center">
        <h2 class="text-2xl font-bold text-gray-800">
          <%= editing ? "Edit" : "Register" %> Your Home
        </h2>
        <p class="text-sm text-gray-500 mt-1">List your property on Airbnb</p>
      </div>

      <input type="hidden" name="id" value="<%= editing ? home._id : '' %>"/>

      <!-- House Name -->
      <input 
        type="text" 
        name="houseName" 
        value="<%= editing ? home.houseName : '' %>"
        placeholder="Enter your house name" 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
        required
      />

      <!-- Price -->
      <input 
        type="number" 
        name="price" 
        value="<%= editing ? home.price : '' %>"
        placeholder="Enter the price per night" 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
        required
      />

      <!-- Location -->
      <input 
        type="text" 
        name="location" 
        value="<%= editing ? home.location : '' %>"
        placeholder="Enter the location" 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
        required
      />

      <!-- Rating -->
      <input 
        type="number" 
        step="0.1"
        max="5"
        name="rating" 
        value="<%= editing ? home.rating : '' %>"
        placeholder="Enter the rating (0-5)" 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
        required
      />

      <!-- Photo URL -->
      <input 
        type="file" 
        name="photo" 
        accept="image/*"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 cursor-pointer hover:border-red-400 transition"
      />

      <!-- Description -->
      <textarea 
        name="description" 
        placeholder="Enter the description" 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
        required
      ><%= editing ? home.description : '' %></textarea>

      <!-- Submit -->
      <button 
        type="submit" 
        class="w-full bg-gradient-to-r from-red-500 to-pink-500 text-white font-semibold py-3 rounded-lg shadow-md hover:from-red-600 hover:to-pink-600 hover:shadow-lg transform hover:scale-[1.02] transition duration-300"
      >
        <%= editing ? 'Update Home' : 'Submit' %>
      </button>
    </form>
  </main>
</body>
</html>
